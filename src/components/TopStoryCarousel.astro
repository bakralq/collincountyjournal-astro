---
import { formatDisplayDate } from '../lib/cityJournalData';
import OptimizedImage from './OptimizedImage.astro';
import { imageWidths } from '../lib/images.js';

const { slides = [] } = Astro.props;
---

<section data-ccj-carousel aria-label="Top city journal stories">
  <div class="overflow-hidden rounded-[2rem] border border-gray-200 bg-white shadow-[0_28px_80px_rgba(17,24,39,0.10)]">
    <div
      class="flex transition-transform duration-700 ease-out"
      data-ccj-carousel-track
      style="transform: translate3d(0, 0, 0);"
    >
      {slides.map((slide, index) => (
        <article
          class={`min-w-full bg-gradient-to-br ${slide.city.panelClass}`}
          data-ccj-carousel-slide
          aria-hidden={index === 0 ? 'false' : 'true'}
        >
          <div class="grid items-center gap-4 p-4 sm:gap-6 sm:p-7 lg:grid-cols-[minmax(0,1.02fr)_minmax(320px,0.98fr)] lg:p-10">
            <div class="order-2 lg:order-1">
              <div class="flex flex-wrap items-center gap-2">
                <span class={`inline-flex rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] ${slide.city.badgeClass}`}>
                  {slide.city.title}
                </span>
                {slide.date && (
                  <span class="text-xs text-gray-600 sm:text-sm">
                    {formatDisplayDate(slide.date, slide.publishedAt)}
                  </span>
                )}
                {slide.readingTime && (
                  <span class="text-xs text-gray-600 sm:text-sm">
                    {slide.readingTime} min read
                  </span>
                )}
              </div>

              <p class="mt-4 text-[11px] font-semibold uppercase tracking-[0.2em] text-gray-500 sm:mt-5 sm:text-xs sm:tracking-[0.22em]">
                Top Story
              </p>

              <h2 class="mt-2 text-[1.9rem] font-bold tracking-tight text-black leading-[1.02] sm:mt-3 sm:text-4xl lg:text-[3.15rem] lg:leading-[1.03]">
                {slide.title}
              </h2>

              <p class="mt-3 max-w-2xl text-[15px] leading-6 text-gray-700 sm:mt-4 sm:text-lg sm:leading-8">
                {slide.description}
              </p>

              <div class="mt-5 flex flex-wrap gap-2.5 sm:mt-7 sm:gap-3">
                <a
                  href={slide.href}
                  target={slide.external ? '_blank' : undefined}
                  rel={slide.external ? 'noopener noreferrer' : undefined}
                  class="inline-flex items-center rounded-full border border-black bg-black px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-white hover:text-black sm:px-5 sm:py-3"
                >
                  {slide.ctaLabel || 'Read full story'}
                </a>

                <a
                  href={slide.city.href}
                  target={slide.city.external ? '_blank' : undefined}
                  rel={slide.city.external ? 'noopener noreferrer' : undefined}
                  class="inline-flex items-center rounded-full border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 transition hover:border-black hover:text-black sm:px-5 sm:py-3"
                >
                  Open {slide.city.shortName} Journal
                </a>
              </div>
            </div>

            <div class="order-1 lg:order-2">
              <a
                href={slide.href}
                target={slide.external ? '_blank' : undefined}
                rel={slide.external ? 'noopener noreferrer' : undefined}
                class="block overflow-hidden rounded-[1.75rem] border border-white/70 bg-white/70 shadow-[0_18px_50px_rgba(17,24,39,0.10)]"
              >
                {slide.image ? (
                  <OptimizedImage
                    src={slide.image}
                    alt={slide.title}
                    class="h-[200px] w-full object-cover sm:h-[320px] lg:h-[380px]"
                    widths={imageWidths.feature}
                    sizes="(min-width: 1024px) 520px, 100vw"
                    loading={index === 0 ? 'eager' : 'lazy'}
                    fetchpriority={index === 0 ? 'high' : undefined}
                  />
                ) : (
                  <div class="flex h-[200px] items-end bg-gradient-to-br from-white via-gray-50 to-gray-100 p-5 sm:h-[320px] sm:p-6 lg:h-[380px]">
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gray-500">
                        {slide.city.title}
                      </p>
                      <p class="mt-3 max-w-sm text-2xl font-semibold tracking-tight text-black">
                        {slide.title}
                      </p>
                    </div>
                  </div>
                )}
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>

  {slides.length > 1 && (
    <>
      <div class="mt-5 flex flex-wrap items-center justify-between gap-4">
        <div class="flex items-center gap-2" data-ccj-carousel-dots>
          {slides.map((slide, index) => (
            <button
              type="button"
              class={`h-2.5 rounded-full transition-all ${index === 0 ? 'w-9 bg-black' : 'w-2.5 bg-gray-300'}`}
              aria-label={`Go to ${slide.city.title}`}
              aria-current={index === 0 ? 'true' : 'false'}
              data-ccj-carousel-dot={index}
            ></button>
          ))}
        </div>

        <div class="hidden items-center gap-2 md:flex">
          <button
            type="button"
            class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-gray-200 bg-white text-lg text-black shadow-sm transition hover:border-black"
            aria-label="Previous story"
            data-ccj-carousel-prev
          >
            ←
          </button>

          <button
            type="button"
            class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-gray-200 bg-white text-lg text-black shadow-sm transition hover:border-black"
            aria-label="Next story"
            data-ccj-carousel-next
          >
            →
          </button>
        </div>
      </div>
    </>
  )}

  <script is:inline>
    (() => {
      const carousels = document.querySelectorAll('[data-ccj-carousel]');

      carousels.forEach((carousel) => {
        if (!(carousel instanceof HTMLElement)) return;

        const track = carousel.querySelector('[data-ccj-carousel-track]');
        const slides = Array.from(carousel.querySelectorAll('[data-ccj-carousel-slide]'));
        const prevButton = carousel.querySelector('[data-ccj-carousel-prev]');
        const nextButton = carousel.querySelector('[data-ccj-carousel-next]');
        const dots = Array.from(carousel.querySelectorAll('[data-ccj-carousel-dot]'));

        if (!(track instanceof HTMLElement) || slides.length <= 1) {
          return;
        }

        let index = 0;
        let timer = 0;
        let touchStartX = 0;
        const mobileMedia = window.matchMedia('(max-width: 767px)');

        const update = () => {
          track.style.transform = `translate3d(-${index * 100}%, 0, 0)`;

          slides.forEach((slide, slideIndex) => {
            slide.setAttribute('aria-hidden', slideIndex === index ? 'false' : 'true');
          });

          dots.forEach((dot, dotIndex) => {
            if (!(dot instanceof HTMLElement)) return;
            dot.setAttribute('aria-current', dotIndex === index ? 'true' : 'false');
            dot.className = dotIndex === index
              ? 'h-2.5 w-9 rounded-full bg-black transition-all'
              : 'h-2.5 w-2.5 rounded-full bg-gray-300 transition-all';
          });
        };

        const stop = () => {
          if (timer) {
            window.clearInterval(timer);
            timer = 0;
          }
        };

        const start = () => {
          stop();
          timer = window.setInterval(() => {
            index = (index + 1) % slides.length;
            update();
          }, 3000);
        };

        const goTo = (nextIndex) => {
          index = (nextIndex + slides.length) % slides.length;
          update();
          start();
        };

        prevButton?.addEventListener('click', () => goTo(index - 1));
        nextButton?.addEventListener('click', () => goTo(index + 1));

        dots.forEach((dot, dotIndex) => {
          dot.addEventListener('click', () => goTo(dotIndex));
        });

        carousel.addEventListener('mouseenter', stop);
        carousel.addEventListener('mouseleave', start);
        carousel.addEventListener('focusin', stop);
        carousel.addEventListener('focusout', start);

        carousel.addEventListener(
          'touchstart',
          (event) => {
            if (!mobileMedia.matches) return;
            touchStartX = event.changedTouches[0]?.clientX || 0;
            stop();
          },
          { passive: true }
        );

        carousel.addEventListener(
          'touchend',
          (event) => {
            if (!mobileMedia.matches) return;
            const touchEndX = event.changedTouches[0]?.clientX || 0;
            const delta = touchEndX - touchStartX;

            if (Math.abs(delta) > 35) {
              goTo(delta > 0 ? index - 1 : index + 1);
              return;
            }

            start();
          },
          { passive: true }
        );

        document.addEventListener('visibilitychange', () => {
          if (document.hidden) {
            stop();
          } else {
            start();
          }
        });

        update();
        start();
      });
    })();
  </script>
</section>
