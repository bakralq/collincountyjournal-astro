---
import { formatDisplayDate } from '../lib/cityJournalData';

const { items = [] } = Astro.props;
---

<div class="-mx-6 overflow-x-auto px-6 pb-4">
  <div class="flex gap-4">
    {items.map((item) => (
      <a
        href={item.href}
        target={item.external ? '_blank' : undefined}
        rel={item.external ? 'noopener noreferrer' : undefined}
        class="group flex min-w-[286px] max-w-[320px] shrink-0 snap-start flex-col overflow-hidden rounded-[1.6rem] border border-gray-200 bg-white shadow-[0_12px_32px_rgba(17,24,39,0.05)] transition hover:-translate-y-0.5 hover:shadow-[0_20px_40px_rgba(17,24,39,0.08)]"
      >
        {item.image ? (
          <img
            src={item.image}
            alt={item.title}
            class="h-44 w-full object-cover"
          />
        ) : (
          <div class="flex h-44 items-end bg-gradient-to-br from-gray-100 via-white to-gray-200 p-5">
            <p class="max-w-[12rem] text-lg font-semibold leading-6 tracking-tight text-black">
              {item.title}
            </p>
          </div>
        )}

        <div class="flex flex-1 flex-col p-5">
          {(item.date || item.readingTime || item.external) && (
            <p class="text-sm text-gray-500">
              {item.date ? formatDisplayDate(item.date) : item.external ? 'External journal' : ''}
              {item.date && item.readingTime ? ' • ' : item.date && item.external ? ' • ' : ''}
              {item.readingTime ? `${item.readingTime} min read` : item.external && !item.date ? 'Open story' : ''}
            </p>
          )}

          <h3 class="mt-2 text-xl font-semibold tracking-tight text-black">
            {item.title}
          </h3>

          <p class="mt-3 text-sm leading-6 text-gray-600">
            {item.description}
          </p>

          <div class="mt-5 text-sm font-semibold text-black">
            {item.ctaLabel || 'Open story →'}
          </div>
        </div>
      </a>
    ))}
  </div>
</div>
