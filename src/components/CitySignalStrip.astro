---
const { city } = Astro.props;
const stats = city?.stats || [];
const iconClass = city?.iconClass || 'bg-gray-100 text-gray-700';
---

<aside class="rounded-[1.75rem] border border-gray-200 bg-white/90 p-4 shadow-[0_18px_45px_rgba(17,24,39,0.06)] sm:p-5">
  <div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gray-500">
        City Snapshot
      </p>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Weather, population, traffic, and public safety at a glance.
      </p>
    </div>
  </div>

  <div class="mt-5 grid grid-cols-2 gap-3 sm:gap-4">
    {stats.map((stat) => (
      <article class="min-w-0 rounded-2xl border border-gray-200 bg-gray-50 p-4">
        <div class="flex items-start gap-3.5">
          <div class={`inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl ${iconClass}`}>
            {stat.icon === 'weather' && (
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="3.5"></circle>
                <path d="M12 2.5v2.2"></path>
                <path d="M12 19.3v2.2"></path>
                <path d="M4.9 4.9l1.6 1.6"></path>
                <path d="M17.5 17.5l1.6 1.6"></path>
                <path d="M2.5 12h2.2"></path>
                <path d="M19.3 12h2.2"></path>
                <path d="M4.9 19.1l1.6-1.6"></path>
                <path d="M17.5 6.5l1.6-1.6"></path>
              </svg>
            )}
            {stat.icon === 'population' && (
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M16 20a4 4 0 0 0-8 0"></path>
                <circle cx="12" cy="10" r="3.2"></circle>
                <path d="M20 20a3.5 3.5 0 0 0-3.1-3.5"></path>
                <path d="M7.1 16.5A3.5 3.5 0 0 0 4 20"></path>
                <path d="M16.7 7.6a2.7 2.7 0 1 1 0 4.8"></path>
                <path d="M7.3 7.6a2.7 2.7 0 1 0 0 4.8"></path>
              </svg>
            )}
            {stat.icon === 'traffic' && (
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M8 3.5h8"></path>
                <path d="M10 3.5v4.2"></path>
                <path d="M14 3.5v4.2"></path>
                <path d="M7 20.5h10"></path>
                <path d="M5.2 11.2 8.5 7.7h7l3.3 3.5v6.8a2.5 2.5 0 0 1-2.5 2.5h-8.6a2.5 2.5 0 0 1-2.5-2.5Z"></path>
                <circle cx="8.5" cy="16.5" r="1"></circle>
                <circle cx="15.5" cy="16.5" r="1"></circle>
              </svg>
            )}
            {stat.icon === 'safety' && (
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 2.5 19 5v6.3c0 4.4-2.6 8.4-7 10.2-4.4-1.8-7-5.8-7-10.2V5Z"></path>
                <path d="m9.2 12.2 1.9 1.9 3.9-4.3"></path>
              </svg>
            )}
          </div>

          <div class="min-w-0">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-gray-500">
              {stat.key}
            </p>
            <p class="mt-1 text-sm font-semibold leading-5 text-black">
              {stat.label}
            </p>
            <p class="mt-1 text-xs leading-5 text-gray-500">
              {stat.detail}
            </p>
          </div>
        </div>
      </article>
    ))}
  </div>
</aside>
