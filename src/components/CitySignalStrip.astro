---
const { city } = Astro.props;
const stats = city?.stats || [];
const iconClass = city?.iconClass || 'bg-gray-100 text-gray-700';
const weather = city?.weather || null;
const traffic = city?.traffic || null;
const weatherApiKey = import.meta.env.PUBLIC_OPENWEATHER_API_KEY || '';
const trafficApiKey = import.meta.env.PUBLIC_TOMTOM_API_KEY || '';
---

<aside
  class="rounded-[1.75rem] border border-gray-200 bg-white/90 p-4 shadow-[0_18px_45px_rgba(17,24,39,0.06)] sm:p-5"
  data-city-signal-strip
  data-weather-lat={weather?.lat}
  data-weather-lon={weather?.lon}
  data-weather-api-key={weatherApiKey}
  data-weather-city={city?.key || ''}
  data-traffic-lat={traffic?.lat}
  data-traffic-lon={traffic?.lon}
  data-traffic-zoom={traffic?.zoom}
  data-traffic-route={traffic?.routeLabel}
  data-traffic-api-key={trafficApiKey}
>
  <div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gray-500">
        City Snapshot
      </p>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Weather, population, traffic, and housing at a glance.
      </p>
    </div>
  </div>

  <div class="mt-5 grid grid-cols-2 gap-2.5 sm:gap-4">
    {stats.map((stat) => (
      <article
        class="min-w-0 overflow-hidden rounded-2xl border border-gray-200 bg-gray-50 p-3 sm:p-4"
        data-weather-card={stat.icon === 'weather' ? 'true' : undefined}
        data-traffic-card={stat.icon === 'traffic' ? 'true' : undefined}
      >
        <div class="flex flex-col items-start gap-3 sm:flex-row sm:items-start sm:gap-3.5">
          <div class={`inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-2xl sm:h-10 sm:w-10 ${iconClass}`}>
            {stat.icon === 'weather' && (
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="3.5"></circle>
                <path d="M12 2.5v2.2"></path>
                <path d="M12 19.3v2.2"></path>
                <path d="M4.9 4.9l1.6 1.6"></path>
                <path d="M17.5 17.5l1.6 1.6"></path>
                <path d="M2.5 12h2.2"></path>
                <path d="M19.3 12h2.2"></path>
                <path d="M4.9 19.1l1.6-1.6"></path>
                <path d="M17.5 6.5l1.6-1.6"></path>
              </svg>
            )}
            {stat.icon === 'population' && (
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M16 20a4 4 0 0 0-8 0"></path>
                <circle cx="12" cy="10" r="3.2"></circle>
                <path d="M20 20a3.5 3.5 0 0 0-3.1-3.5"></path>
                <path d="M7.1 16.5A3.5 3.5 0 0 0 4 20"></path>
                <path d="M16.7 7.6a2.7 2.7 0 1 1 0 4.8"></path>
                <path d="M7.3 7.6a2.7 2.7 0 1 0 0 4.8"></path>
              </svg>
            )}
            {stat.icon === 'traffic' && (
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M8 3.5h8"></path>
                <path d="M10 3.5v4.2"></path>
                <path d="M14 3.5v4.2"></path>
                <path d="M7 20.5h10"></path>
                <path d="M5.2 11.2 8.5 7.7h7l3.3 3.5v6.8a2.5 2.5 0 0 1-2.5 2.5h-8.6a2.5 2.5 0 0 1-2.5-2.5Z"></path>
                <circle cx="8.5" cy="16.5" r="1"></circle>
                <circle cx="15.5" cy="16.5" r="1"></circle>
              </svg>
            )}
            {stat.icon === 'housing' && (
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3.5 10.3 12 3.5l8.5 6.8"></path>
                <path d="M5.5 9.6v10.9h13V9.6"></path>
                <path d="M9.5 20.5v-5.4h5v5.4"></path>
              </svg>
            )}
          </div>

          <div class="min-w-0">
            <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-gray-500 sm:text-[11px] sm:tracking-[0.18em]">
              {stat.key}
            </p>
            <p
              class="mt-1 break-words text-sm font-semibold leading-5 text-black"
              data-weather-label={stat.icon === 'weather' ? 'true' : undefined}
              data-traffic-label={stat.icon === 'traffic' ? 'true' : undefined}
            >
              {stat.label}
            </p>
            <p
              class="mt-1 text-[11px] leading-4 text-gray-500 sm:text-xs sm:leading-5"
              data-weather-detail={stat.icon === 'weather' ? 'true' : undefined}
              data-traffic-detail={stat.icon === 'traffic' ? 'true' : undefined}
            >
              {stat.detail}
            </p>
          </div>
        </div>
      </article>
    ))}
  </div>
</aside>

<script is:inline>
  const CITY_SIGNAL_STRIP_SELECTOR = '[data-city-signal-strip]';
  const WEATHER_CACHE_TTL = 15 * 60 * 1000;
  const TRAFFIC_CACHE_TTL = 10 * 60 * 1000;

  const toTitleCase = (value) =>
    value.replace(/\b\w/g, (match) => match.toUpperCase());

  const applyWeather = (strip, payload) => {
    const label = strip.querySelector('[data-weather-label]');
    const detail = strip.querySelector('[data-weather-detail]');

    if (!label || !detail) return;

    if (typeof payload?.temp === 'number') {
      label.textContent = `${Math.round(payload.temp)}°`;
    }

    if (payload?.description) {
      detail.textContent = toTitleCase(payload.description);
    }
  };

  const applyTraffic = (strip, payload) => {
    const label = strip.querySelector('[data-traffic-label]');
    const detail = strip.querySelector('[data-traffic-detail]');

    if (!label || !detail) return;

    if (payload?.label) {
      label.textContent = payload.label;
    }

    if (payload?.detail) {
      detail.textContent = payload.detail;
    }
  };

  const classifyTraffic = (segment, routeLabel) => {
    const currentSpeed = Number(segment?.currentSpeed);
    const freeFlowSpeed = Number(segment?.freeFlowSpeed);
    const roadClosure = Boolean(segment?.roadClosure);

    if (roadClosure) {
      return {
        label: 'Closed',
        detail: `${routeLabel} closure flagged`,
      };
    }

    if (!Number.isFinite(currentSpeed) || !Number.isFinite(freeFlowSpeed) || freeFlowSpeed <= 0) {
      return {
        label: 'Live',
        detail: `${routeLabel} conditions loading`,
      };
    }

    const flowRatio = currentSpeed / freeFlowSpeed;
    let label = 'Moderate';

    if (flowRatio >= 0.85) {
      label = 'Light';
    } else if (flowRatio >= 0.65) {
      label = 'Moderate';
    } else if (flowRatio >= 0.45) {
      label = 'Heavy';
    } else {
      label = 'Severe';
    }

    return {
      label,
      detail: `${routeLabel} at ${Math.round(currentSpeed)} mph`,
    };
  };

  const loadCityWeather = async (strip) => {
    if (strip.dataset.weatherLoaded === 'true') return;
    strip.dataset.weatherLoaded = 'true';

    const apiKey = strip.dataset.weatherApiKey;
    const lat = strip.dataset.weatherLat;
    const lon = strip.dataset.weatherLon;
    const cityKey = strip.dataset.weatherCity || 'city';

    if (!apiKey || !lat || !lon) return;

    const cacheKey = `ccj-weather-${cityKey}`;

    try {
      const cachedValue = window.localStorage.getItem(cacheKey);

      if (cachedValue) {
        const cached = JSON.parse(cachedValue);

        if (cached?.timestamp && Date.now() - cached.timestamp < WEATHER_CACHE_TTL) {
          applyWeather(strip, cached);
          return;
        }
      }
    } catch {}

    try {
      const response = await fetch(
        `https://api.openweathermap.org/data/2.5/weather?lat=${encodeURIComponent(lat)}&lon=${encodeURIComponent(lon)}&units=imperial&appid=${encodeURIComponent(apiKey)}`
      );

      if (!response.ok) return;

      const json = await response.json();
      const payload = {
        temp: json?.main?.temp,
        description: json?.weather?.[0]?.description || 'Current conditions',
        timestamp: Date.now(),
      };

      applyWeather(strip, payload);

      try {
        window.localStorage.setItem(cacheKey, JSON.stringify(payload));
      } catch {}
    } catch {}
  };

  const loadCityTraffic = async (strip) => {
    if (strip.dataset.trafficLoaded === 'true') return;
    strip.dataset.trafficLoaded = 'true';

    const apiKey = strip.dataset.trafficApiKey;
    const lat = strip.dataset.trafficLat;
    const lon = strip.dataset.trafficLon;
    const zoom = strip.dataset.trafficZoom || '12';
    const routeLabel = strip.dataset.trafficRoute || 'Main corridor';
    const cityKey = strip.dataset.weatherCity || 'city';

    if (!apiKey || !lat || !lon) return;

    const cacheKey = `ccj-traffic-${cityKey}`;

    try {
      const cachedValue = window.localStorage.getItem(cacheKey);

      if (cachedValue) {
        const cached = JSON.parse(cachedValue);

        if (cached?.timestamp && Date.now() - cached.timestamp < TRAFFIC_CACHE_TTL) {
          applyTraffic(strip, cached);
          return;
        }
      }
    } catch {}

    try {
      const response = await fetch(
        `https://api.tomtom.com/traffic/services/4/flowSegmentData/absolute/${encodeURIComponent(zoom)}/json?key=${encodeURIComponent(apiKey)}&point=${encodeURIComponent(`${lat},${lon}`)}&unit=mph`
      );

      if (!response.ok) return;

      const json = await response.json();
      const segment = json?.flowSegmentData;
      const trafficState = classifyTraffic(segment, routeLabel);
      const payload = {
        ...trafficState,
        timestamp: Date.now(),
      };

      applyTraffic(strip, payload);

      try {
        window.localStorage.setItem(cacheKey, JSON.stringify(payload));
      } catch {}
    } catch {}
  };

  const initCitySignalStrips = () => {
    document.querySelectorAll(CITY_SIGNAL_STRIP_SELECTOR).forEach((strip) => {
      loadCityWeather(strip);
      loadCityTraffic(strip);
    });
  };

  document.addEventListener('astro:page-load', initCitySignalStrips);
  initCitySignalStrips();
</script>
