---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import {
  PUBLISHER,
  buildBreadcrumbSchema,
  getAuthorProfile,
  getSectionHref,
  toAbsoluteUrl,
} from '../../lib/seo';
import { getPostDateObject, getPostTimestamp } from '../../lib/cityJournalData';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const rawContent = post.body || '';
const wordCount = rawContent.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const slug = post.id.replace(/\.md$/, '');
const articlePath = `/posts/${slug}`;
const articleUrl = toAbsoluteUrl(articlePath);
const sectionHref = getSectionHref(post.data.section);
const authorProfile = getAuthorProfile(post.data.author);

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const sectionPosts = allPosts
  .filter((p) => p.data.section === post.data.section)
  .sort(
    (a, b) =>
      getPostTimestamp(b.data.date, b.data.publishedAt) -
      getPostTimestamp(a.data.date, a.data.publishedAt)
  );

const currentIndex = sectionPosts.findIndex(
  (p) => p.id.replace(/\.md$/, '') === slug
);

let nextPost = null;

if (currentIndex === 0) {
  nextPost = sectionPosts[1] ?? null;
} else {
  nextPost = sectionPosts[0] ?? null;
}

const getReadingTime = (content = '') => {
  const sectionWordCount = content.trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(sectionWordCount / 200));
};

const nextPostData = nextPost
  ? {
      title: nextPost.data.title,
      href: `/posts/${nextPost.id.replace(/\.md$/, '')}`,
      date: nextPost.data.date,
      publishedAt: nextPost.data.publishedAt || '',
      image: nextPost.data.image || null,
      readingTime: getReadingTime(nextPost.body || ''),
    }
  : null;

const relatedPosts = sectionPosts
  .filter((candidate) => candidate.id !== post.id && candidate.id !== nextPost?.id)
  .slice(0, 3)
  .map((candidate) => ({
    title: candidate.data.title,
    description: candidate.data.description,
    href: `/posts/${candidate.id.replace(/\.md$/, '')}`,
    date: candidate.data.date,
    publishedAt: candidate.data.publishedAt || '',
    image: candidate.data.image || null,
    readingTime: getReadingTime(candidate.body || ''),
  }));

const imageUrl = post.data.image ? toAbsoluteUrl(post.data.image) : null;
const datePublished = getPostDateObject(post.data.date, post.data.publishedAt)?.toISOString() || post.data.date;
const dateModified =
  getPostDateObject(
    post.data.updated || post.data.date,
    post.data.updated ? undefined : post.data.publishedAt
  )?.toISOString() || post.data.updated || post.data.date;
const keywords = Array.from(
  new Set(
    [post.data.section, 'Collin County Journal', ...(post.data.keywords || [])].filter(Boolean)
  )
);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: post.data.title,
  description: post.data.description,
  datePublished,
  dateModified,
  author: authorProfile,
  publisher: PUBLISHER,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': articleUrl,
  },
  url: articleUrl,
  articleSection: post.data.section,
  inLanguage: 'en-US',
  isAccessibleForFree: true,
  wordCount,
  ...(imageUrl
    ? {
        image: [
          {
            '@type': 'ImageObject',
            url: imageUrl,
          },
        ],
        thumbnailUrl: imageUrl,
      }
    : {}),
  ...(keywords.length > 0 ? { keywords } : {}),
};

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', item: '/' },
  ...(sectionHref ? [{ name: post.data.section, item: sectionHref }] : []),
  { name: post.data.title, item: articlePath },
]);

const pageSchemas = [breadcrumbSchema, articleSchema];
---

<script type="application/ld+json" set:html={JSON.stringify(pageSchemas)} />

<ArticleLayout
  title={post.data.title}
  section={post.data.section}
  sectionHref={sectionHref}
  author={post.data.author}
  authorHref={authorProfile.url}
  date={post.data.date}
  publishedAt={post.data.publishedAt}
  updated={post.data.updated}
  description={post.data.description}
  url={articleUrl}
  image={post.data.image}
  imageCaption={post.data.imageCaption}
  imageSourceUrl={post.data.imageSourceUrl}
  preview={post.data.preview}
  readingTime={readingTime}
  relatedPosts={relatedPosts}
  nextPost={nextPostData}
>
  <Content />
</ArticleLayout>
