---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="You’re Subscribed | Collin County Journal"
  description="Thanks for subscribing to Collin County Journal."
  url="https://collincountyjournal.com/subscribe-thank-you"
>
  <main class="mx-auto max-w-4xl px-6 py-14">
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      Subscribe
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      You’re on the list.
    </h1>

    <div class="mt-8 space-y-6 text-lg leading-8 text-gray-800">
      <p>
        Thanks for subscribing to Collin County Journal.
      </p>

      <p>
        We’ll use this list for major reporting, meaningful civic updates, and the biggest city-journal stories across Collin County, or the city you selected.
      </p>

      <div class="pt-4">
        <a
          href="/"
          class="rounded-xl border border-black px-5 py-3 text-sm font-medium transition hover:bg-black hover:text-white"
        >
          Return to Home
        </a>
      </div>
    </div>
  </main>
</Layout>
