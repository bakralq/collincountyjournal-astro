---
import Layout from '../layouts/Layout.astro';
import { subscribeAudienceOptions } from '../lib/cityJournalData';
---

<Layout
  title="Subscribe | Collin County Journal"
  description="Subscribe to Collin County Journal for local news updates from across Collin County."
  url="https://collincountyjournal.com/subscribe"
>
  <main class="mx-auto max-w-4xl px-6 py-10">
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      Subscribe
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      Subscribe to Collin County Journal
    </h1>

    <div class="mt-8 space-y-6 text-lg leading-8 text-gray-800">
      <p>
        Subscribe to receive email updates from Collin County Journal, including major local reporting, important civic coverage, and significant updates from across Princeton, Celina, Prosper, Anna, and Melissa.
      </p>

      <p>
        By subscribing, you agree to receive email updates from Collin County Journal. You can unsubscribe at any time.
      </p>

      <form
        name="newsletter-subscribe"
        method="POST"
        action="/subscribe-thank-you"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="mt-8 space-y-6 rounded-2xl border border-gray-200 p-6 shadow-sm"
      >
        <input type="hidden" name="form-name" value="newsletter-subscribe" />
        <input type="hidden" name="signup_source" value="subscribe-page" />

        <p class="hidden">
          <label>
            Don’t fill this out if you’re human:
            <input name="bot-field" />
          </label>
        </p>

        <div>
          <label class="mb-2 block text-sm font-medium text-gray-700">
            Which updates do you want?
          </label>
          <select
            name="subscription_preference"
            class="w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-base outline-none focus:border-black"
          >
            {subscribeAudienceOptions.map((option) => (
              <option value={option.value}>{option.label}</option>
            ))}
          </select>
        </div>

        <div>
          <label class="mb-2 block text-sm font-medium text-gray-700">
            Your Email
          </label>
          <input
            type="email"
            name="email"
            required
            placeholder="you@example.com"
            class="w-full rounded-xl border border-gray-300 px-4 py-3 text-base outline-none focus:border-black"
          />
        </div>

        <button
          type="submit"
          class="rounded-xl border border-black px-5 py-3 text-sm font-medium transition hover:bg-black hover:text-white"
        >
          Subscribe
        </button>
      </form>

      <p class="text-base text-gray-600">
        We use this list to send occasional news updates, major reporting, and important coverage from across Collin County, or just the city you selected.
      </p>
    </div>
  </main>
</Layout>
