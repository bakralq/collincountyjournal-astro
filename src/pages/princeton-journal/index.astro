---
const destination = 'https://theprincetonjournal.com';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="refresh" content={`0; url=${destination}`} />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Redirecting to The Princeton Journal</title>
  <link rel="canonical" href={destination} />
</head>
<body>
  <p>
    Redirecting to <a href={destination}>The Princeton Journal</a>.
  </p>
</body>
</html>
