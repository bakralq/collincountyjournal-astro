---
import { getCollection } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import Layout from '../layouts/Layout.astro';
import TopStoryCarousel from '../components/TopStoryCarousel.astro';
import { buildCollectionPageSchema } from '../lib/seo';
import {
  cityJournalConfigs,
  createPlaceholderStory,
  internalCityJournalConfigs,
  sortPostsByDate,
  toExternalStoryCard,
  toLocalStoryCard,
} from '../lib/cityJournalData';
import { getPrincetonFeed } from '../lib/princetonFeed.js';

const allPosts = sortPostsByDate(
  await getCollection('posts', ({ data }) => !data.draft)
);

const getSectionCards = (section) =>
  allPosts
    .filter((post) => post.data.section === section)
    .map((post) => toLocalStoryCard(post));

const localCityStories = Object.fromEntries(
  internalCityJournalConfigs.map((city) => [city.key, getSectionCards(city.section)])
);

const princetonFeed = (await getPrincetonFeed(4)).map((item) =>
  toExternalStoryCard(item)
);

const carouselSlides = cityJournalConfigs.map((city) => {
  if (city.external) {
    const top = princetonFeed[0];
    return {
      city,
      ...(top || createPlaceholderStory(city)),
      ctaLabel: top ? 'Read full story' : 'Open journal',
    };
  }

  const top = localCityStories[city.key]?.[0];

  return {
    city,
    ...(top || createPlaceholderStory(city)),
    ctaLabel: top ? 'Read full story' : 'See what’s coming',
  };
});

const countywideStories = allPosts
  .filter((post) => post.data.section === 'US News')
  .slice(0, 3)
  .map((post) => ({
    title: post.data.title,
    description: post.data.description,
    href: `/posts/${post.id.replace(/\.md$/, '')}`,
    date: post.data.date,
    image: post.data.image || null,
    readingTime: toLocalStoryCard(post).readingTime,
  }));

const homeSchema = buildCollectionPageSchema({
  name: 'Collin County Journal',
  description:
    'Independent reporting across Anna, Celina, Melissa, Princeton, and Prosper, plus countywide and U.S. coverage.',
  url: '/',
  items: [
    ...cityJournalConfigs.map((city) => ({
      name: city.title,
      url: city.external ? 'https://theprincetonjournal.com' : city.href,
    })),
    ...countywideStories.map((story) => ({
      name: story.title,
      url: story.href,
    })),
  ],
});
---

<Layout
  title="Collin County Journal"
  description="Collin County Journal is an independent news publication covering local government, public safety, development, schools, elections, and community news across Collin County, Texas."
  url="https://collincountyjournal.com"
>
  <script type="application/ld+json" set:html={JSON.stringify(homeSchema)} />

  <main class="mx-auto max-w-6xl px-6 py-10">
    <section class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gray-500">
        Collin County Journal
      </p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-black sm:text-5xl lg:text-6xl">
        Five city journals. One county hub.
      </h1>
      <p class="mt-5 text-lg leading-8 text-gray-600">
        Start with the biggest story in each city journal, then move into the part of Collin County you care about most.
      </p>
    </section>

    <section class="mt-10">
      <TopStoryCarousel slides={carouselSlides} />
    </section>

    {countywideStories.length > 0 && (
      <section class="mt-14 border-t border-gray-200 pt-12">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gray-500">
              County + U.S. Context
            </p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight text-black">
              The wider picture
            </h2>
          </div>

          <a
            href="/us-news"
            class="text-sm font-semibold text-gray-600 transition hover:text-black"
          >
            Open US News
          </a>
        </div>

        <div class="mt-6 grid gap-6 md:grid-cols-3">
          {countywideStories.map((story) => (
            <ArticleCard
              title={story.title}
              description={story.description}
              href={story.href}
              date={story.date}
              image={story.image}
              readingTime={story.readingTime}
              variant="stacked"
            />
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>
