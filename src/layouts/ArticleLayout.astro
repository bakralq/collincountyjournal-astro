---
import Layout from './Layout.astro';
import ArticleInlineSubscribe from '../components/ArticleInlineSubscribe.astro';
import ArticleCard from '../components/ArticleCard.astro';
import AdSlot from '../components/AdSlot.astro';
import ArticlePollWidget from '../components/ArticlePollWidget.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import { formatDisplayDate, getCityConfigBySection } from '../lib/cityJournalData';
import { imageWidths } from '../lib/images.js';

const {
  title,
  section,
  sectionHref = null,
  author,
  authorHref = '/staff',
  date,
  publishedAt = '',
  updated = '',
  description,
  url,
  image,
  imageCaption,
  imageSourceUrl,
  nextPost,
  relatedPosts = [],
  readingTime,
  preview,
  slug = '',
} = Astro.props;
const subscribeCity = getCityConfigBySection(section);
const pollQuestions = {
  'epic-city-the-meadow-still-moving-forward-2026': 'Should The Meadow / EPIC City move forward?',
};
const pollQuestion = pollQuestions[slug];
---

<Layout
  title={`${title} | Collin County Journal`}
  description={description}
  url={url}
  ogImage={image ? `https://collincountyjournal.com${image}` : 'https://collincountyjournal.com/ccj-logo.jpg'}
  ogType="article"
  subscribeCity={subscribeCity?.key}
>
  <main class="mx-auto max-w-3xl px-6 py-16">
    <nav aria-label="Breadcrumb" class="text-sm text-gray-500">
      <ol class="flex flex-wrap items-center gap-2">
        <li>
          <a href="/" class="transition hover:text-black">Home</a>
        </li>
        <li aria-hidden="true">/</li>
        <li>
          {sectionHref ? (
            <a href={sectionHref} class="transition hover:text-black">
              {section}
            </a>
          ) : (
            <span>{section}</span>
          )}
        </li>
      </ol>
    </nav>

    <p class="mt-6 text-sm font-medium uppercase tracking-wide text-gray-500">
      {sectionHref ? (
        <a href={sectionHref} class="transition hover:text-black">
          {section}
        </a>
      ) : (
        section
      )}
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      {title}
    </h1>

    {author && (
      <p class="mt-4 text-sm text-gray-600">
        By <a href={authorHref} class="no-underline hover:underline">{author}</a>
      </p>
    )}

    {date && (
      <p class="mt-1 text-sm text-gray-500">
        {formatDisplayDate(date, publishedAt)}
        {readingTime && ` • ${readingTime} min read`}
        {updated && updated !== date && (
          <>
            {' • Updated '}
            {formatDisplayDate(updated)}
          </>
        )}
      </p>
    )}

{image && (
  <>
    <OptimizedImage
      src={image}
      alt={title}
      class="mt-8 w-full rounded-xl border border-gray-200 object-cover"
      widths={imageWidths.hero}
      sizes="(min-width: 768px) 768px, calc(100vw - 48px)"
      loading="eager"
      fetchpriority="high"
    />
    {imageCaption && (
      <p class="mt-2 text-sm text-gray-500">
        {imageSourceUrl ? (
          <a
            href={imageSourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="underline underline-offset-2 transition hover:text-gray-700"
          >
            {imageCaption}
          </a>
        ) : (
          imageCaption
        )}
      </p>
    )}
  </>
)}

    {preview ? (
      <>
        <div class="article-content mt-10 text-lg leading-8 text-gray-800">
          <p>{preview}</p>
        </div>

        <div class="relative mt-8 overflow-hidden rounded-2xl border border-gray-200 bg-white">
          <div class="pointer-events-none max-h-64 overflow-hidden px-6 pt-6 pb-20 opacity-75 blur-[2px]">
            <article class="article-content text-lg leading-8 text-gray-800">
              <slot />
            </article>
          </div>

          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-white via-white/95 to-transparent px-6 pb-6 pt-16 text-center">
            <button
              id="readMoreButton"
              class="inline-flex items-center rounded-xl border border-black bg-black px-6 py-3 text-base font-semibold text-white transition hover:bg-white hover:text-black"
            >
              Read more
            </button>
          </div>
        </div>

        <article id="fullArticle" data-article-body class="article-content mt-10 hidden text-lg leading-8 text-gray-800">
          <slot />
        </article>
      </>
    ) : (
      <article data-article-body class="article-content mt-10 text-lg leading-8 text-gray-800">
        <slot />
      </article>
    )}

    <button
      type="button"
      class="article-back-to-top"
      data-article-back-to-top
      aria-label="Back to top"
      hidden
    >
      ↑
    </button>

    <template id="articleInlineSubscribeTemplate">
      <ArticleInlineSubscribe contextCity={subscribeCity?.key || ''} />
    </template>

    <template id="articleAdSlotTemplate">
      <AdSlot compact={true} />
    </template>

    <script is:inline>
      (() => {
        const button = document.getElementById('readMoreButton');
        const fullArticle = document.getElementById('fullArticle');
        const template = document.getElementById('articleInlineSubscribeTemplate');
        const adTemplate = document.getElementById('articleAdSlotTemplate');

        button?.addEventListener('click', () => {
          const previewBlock = button.closest('.relative');
          if (previewBlock) previewBlock.remove();
          fullArticle?.classList.remove('hidden');
          requestAnimationFrame(installInlinePrompts);
        });

        if (!(template instanceof HTMLTemplateElement)) {
          return;
        }

        const bindInlineForm = (card) => {
          if (!(card instanceof HTMLElement)) {
            return;
          }

          const form = card.querySelector('[data-inline-subscribe-form]');
          const success = card.querySelector('[data-inline-subscribe-success]');

          if (!(form instanceof HTMLFormElement) || form.dataset.bound === 'true') {
            return;
          }

          form.dataset.bound = 'true';

          form.addEventListener('submit', async (event) => {
            event.preventDefault();

            const formData = new FormData(form);
            const body = new URLSearchParams();

            for (const [key, value] of formData.entries()) {
              if (typeof value === 'string') {
                body.append(key, value);
              }
            }

            try {
              const response = await fetch('/', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: body.toString(),
              });

              if (!response.ok) {
                throw new Error('Subscribe request failed');
              }

              form.classList.add('hidden');
              success?.classList.remove('hidden');
            } catch {
              form.submit();
            }
          });
        };

        const createCard = () => {
          const wrapper = document.createElement('div');
          wrapper.appendChild(template.content.cloneNode(true));
          const card = wrapper.firstElementChild;
          bindInlineForm(card);
          return card instanceof HTMLElement ? card : null;
        };

        const createAdSlot = () => {
          if (!(adTemplate instanceof HTMLTemplateElement)) {
            return null;
          }

          const wrapper = document.createElement('div');
          wrapper.appendChild(adTemplate.content.cloneNode(true));
          const ad = wrapper.firstElementChild;
          return ad instanceof HTMLElement ? ad : null;
        };

        const isHeading = (element) =>
          element instanceof HTMLElement &&
          /^H[2-3]$/.test(element.tagName);

        const headingText = (element) =>
          element instanceof HTMLElement
            ? element.textContent?.trim().toLowerCase() || ''
            : '';

        const findQuickReadEnd = (quickReadHeading) => {
          let current = quickReadHeading.nextElementSibling;
          let lastContent = quickReadHeading;

          while (current) {
            if (isHeading(current)) break;

            if (
              current instanceof HTMLElement &&
              ['P', 'UL', 'OL', 'DIV'].includes(current.tagName)
            ) {
              lastContent = current;
            }

            current = current.nextElementSibling;
          }

          return lastContent;
        };

        const installArticleAd = (container) => {
          if (!(container instanceof HTMLElement) || container.dataset.articleAdInjected === 'true') {
            return;
          }

          const ad = createAdSlot();
          if (!ad) return;

          const quickReadHeading = Array.from(
            container.querySelectorAll(':scope > h2, :scope > h3')
          ).find((element) => headingText(element).includes('quick read'));

          if (quickReadHeading instanceof HTMLElement) {
            const quickReadEnd = findQuickReadEnd(quickReadHeading);
            quickReadEnd.insertAdjacentElement('afterend', ad);
            container.dataset.articleAdInjected = 'true';
            return;
          }

          const fallbackTargets = Array.from(
            container.querySelectorAll(':scope > p, :scope > ul, :scope > ol')
          ).filter((element) => element instanceof HTMLElement);

          const fallbackAnchor = fallbackTargets[Math.min(2, fallbackTargets.length - 1)];
          if (fallbackAnchor instanceof HTMLElement) {
            fallbackAnchor.insertAdjacentElement('afterend', ad);
            container.dataset.articleAdInjected = 'true';
          }
        };

        const injectInto = (container) => {
          if (!(container instanceof HTMLElement) || container.dataset.inlineSubscribeInjected === 'true') {
            return;
          }

          const quickReadHeading = Array.from(
            container.querySelectorAll(':scope > h2, :scope > h3')
          ).find((element) =>
            element instanceof HTMLElement &&
            element.textContent?.trim().toLowerCase() === 'quick read'
          );

          if (quickReadHeading instanceof HTMLElement) {
            const card = createCard();

            if (!card) {
              return;
            }

            quickReadHeading.insertAdjacentElement('beforebegin', card);
            container.dataset.inlineSubscribeInjected = 'true';
            return;
          }

          const targets = Array.from(
            container.querySelectorAll(':scope > p, :scope > ul, :scope > ol')
          ).filter(
            (element) =>
              element instanceof HTMLElement &&
              !element.classList.contains('article-hero-caption')
          );

          if (targets.length < 2) {
            return;
          }

          const insertionIndex = Math.min(
            targets.length - 1,
            Math.max(1, Math.floor(targets.length * 0.28))
          );
          const anchor = targets[insertionIndex];
          const card = createCard();

          if (!card || !(anchor instanceof HTMLElement)) {
            return;
          }

          anchor.insertAdjacentElement('afterend', card);
          container.dataset.inlineSubscribeInjected = 'true';
        };

        function installInlinePrompts() {
          document
            .querySelectorAll('[data-article-body]')
            .forEach((container) => {
              injectInto(container);
              installArticleAd(container);
            });
        }

        const installJumpNavigation = () => {
          const jumpNav = document.querySelector('[data-jump-nav]');
          const backToTopButton = document.querySelector('[data-article-back-to-top]');

          if (!(jumpNav instanceof HTMLElement) || !(backToTopButton instanceof HTMLButtonElement)) {
            return;
          }

          const topOffset = 112;
          let isVisible = false;

          const updateVisibility = () => {
            const threshold = jumpNav.getBoundingClientRect().bottom + window.scrollY + 24;
            const nextVisible = window.scrollY > threshold;

            if (nextVisible === isVisible) {
              return;
            }

            isVisible = nextVisible;
            backToTopButton.hidden = !isVisible;
            backToTopButton.classList.toggle('is-visible', isVisible);
          };

          jumpNav.querySelectorAll('a[href^="#"]').forEach((link) => {
            link.addEventListener('click', (event) => {
              const href = link.getAttribute('href');

              if (!href || href === '#') {
                return;
              }

              const target = document.querySelector(href);

              if (!(target instanceof HTMLElement)) {
                return;
              }

              event.preventDefault();

              const top = target.getBoundingClientRect().top + window.scrollY - topOffset;

              window.scrollTo({
                top,
                behavior: 'smooth',
              });

              if (history.replaceState) {
                history.replaceState(null, '', href);
              } else {
                window.location.hash = href;
              }
            });
          });

          backToTopButton.addEventListener('click', () => {
            window.scrollTo({
              top: 0,
              behavior: 'smooth',
            });
          });

          window.addEventListener('scroll', updateVisibility, { passive: true });
          updateVisibility();
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', () => {
            installInlinePrompts();
            installJumpNavigation();
          }, {
            once: true,
          });
        } else {
          installInlinePrompts();
          installJumpNavigation();
        }
      })();
    </script>

    {relatedPosts.length > 0 && (
      <section class="mt-14 border-t border-gray-200 pt-8">
        <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
          More in {section}
        </p>

        <div class="mt-4 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {relatedPosts.map((story) => (
            <ArticleCard
              title={story.title}
              description={story.description}
              href={story.href}
              date={story.date}
              publishedAt={story.publishedAt}
              image={story.image}
              readingTime={story.readingTime}
              variant="stacked"
            />
          ))}
        </div>
      </section>
    )}

    {nextPost && (
      <section class="mt-14 border-t border-gray-200 pt-8">
        <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
          Read next
        </p>

        <a
          href={nextPost.href}
          class="mt-3 block overflow-hidden rounded-xl border border-gray-200 transition hover:border-gray-300 hover:shadow-sm"
        >
          <div class="flex flex-col sm:flex-row">
            {nextPost.image && (
              <div class="sm:w-1/4 shrink-0">
                <OptimizedImage
                  src={nextPost.image}
                  alt={nextPost.title}
                  class="h-40 w-full object-cover"
                  widths={imageWidths.card}
                  sizes="(min-width: 640px) 25vw, 100vw"
                />
              </div>
            )}

            <div class={`p-6 ${nextPost.image ? 'sm:w-3/4' : 'w-full'}`}>
              {(nextPost.date || nextPost.readingTime) && (
                <p class="text-sm text-gray-500">
                  {nextPost.date && formatDisplayDate(nextPost.date, nextPost.publishedAt)}
                  {nextPost.date && nextPost.readingTime ? ' • ' : ''}
                  {nextPost.readingTime ? `${nextPost.readingTime} min read` : ''}
                </p>
              )}

              <h2 class="mt-1 text-xl font-semibold tracking-tight">
                {nextPost.title}
              </h2>
            </div>
          </div>
        </a>
      </section>
    )}

    {pollQuestion && (
      <ArticlePollWidget slug={slug} question={pollQuestion} />
    )}
  </main>
</Layout>
